# ========================================
# ReceiptAI Backend — Variables de entorno
# Copia este archivo a .env y completa los valores
# ========================================

# Servidor
PORT=3000
NODE_ENV=development
API_VERSION=v1

# CORS — URL del frontend en producción (opcional en desarrollo)
FRONTEND_URL=https://tu-app.railway.app

# AWS — S3 + Textract
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET_NAME=receiptai-images

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic (Claude Haiku — OCR enrichment)
ANTHROPIC_API_KEY=sk-ant-api03-...
